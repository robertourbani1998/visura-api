# Copia in .env: cp .env.example .env

# === Modalità autenticazione ===
# "sister" usa credenziali dirette Sister/AgE
# "spid"   usa Sielte ID (default del progetto originale)
AUTH_TYPE=sister

# === Credenziali Sister ===
# Non vanno qui: vengono passate a runtime da cercavisure via POST /login
# (run.py le inietta in os.environ["ADE_USERNAME"] / ADE_PASSWORD)

# === Configurazione ===
LOG_LEVEL=INFO
CONCURRENT_WORKERS=3

# Non modificare (necessarie per Playwright in Docker)
PYTHONUNBUFFERED=1
DISPLAY=:99
